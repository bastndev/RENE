{
  "name": "rene",
  "displayName": "R E N E",
  "description": "Available now: VSCode • Antigravity • Cursor • Windsurf • Trae.ai • Kiro & (Firebase Studio)... 雨",
  "version": "0.0.1",
  "publisher": "bastndev",
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "Youtube Music",
    "Pomodoro",
    "Game One"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0a0a0a",
    "theme": "dark"
  },
  "homepage": "https://github.com/bastndev/RENE#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/bastndev/RENE"
  },
  "bugs": {
    "url": "https://github.com/bastndev/RENE/issues"
  },
  "author": {
    "name": "Gohit Bastian",
    "email": "hello@gohit.xyz",
    "url": "https://www.gohit.xyz/me"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/bastndev"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "rene-yt-music-view",
          "name": "ATMㅤㅤMUSIC ♪ ( TIME ~ GAME ) ",
          "icon": "$(music)"
        }
      ]
    },
    "configuration": {
      "title": "ATM",
      "properties": {
        "rene.lastfmApiKey": {
          "type": "string",
          "default": "",
          "description": "Last.FM API key for additional music metadata. Get yours at https://www.last.fm/api/account/create"
        },
        "rene.jamendoClientId": {
          "type": "string",
          "default": "b0838540",
          "description": "Jamendo API Client ID for free track streaming. Get yours at https://developer.jamendo.com/v3.0"
        },
        "rene.jiosaavnApiUrl": {
          "type": "string",
          "default": "https://jiosaavn-api-sigma-sandy.vercel.app",
          "description": "JioSaavn API URL (self-host recommended: https://github.com/sumitkolhe/jiosaavn-api)"
        },
        "rene.yandexToken": {
          "type": "string",
          "default": "",
          "description": "Yandex Music OAuth token"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.74.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "NeteaseCloudMusicApi": "^4.30.0"
  }
}
