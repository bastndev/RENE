{
  "name": "rene",
  "displayName": "R E N E",
  "description": "Available now: VSCode • Antigravity • Cursor • Windsurf • Trae.ai • Kiro & (Firebase Studio)... 雨",
  "version": "0.0.1",
  "publisher": "bastndev",
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "Youtube Music",
    "Pomodoro",
    "Game One"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0a0a0a",
    "theme": "dark"
  },
  "homepage": "https://github.com/bastndev/RENE#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/bastndev/RENE"
  },
  "bugs": {
    "url": "https://github.com/bastndev/RENE/issues"
  },
  "author": {
    "name": "Gohit Bastian",
    "email": "hello@gohit.xyz",
    "url": "https://www.gohit.xyz/me"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/bastndev"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rene-activitybar",
          "title": "R E N E",
          "icon": "src/assets/icons/icon-rene.svg"
        }
      ]
    },
    "views": {
      "rene-activitybar": [
        {
          "id": "rene-one-game-view",
          "name": "One Game",
          "icon": "$(game)"
        },
        {
          "id": "rene-pomodoro-view",
          "name": "Pomodoro",
          "icon": "$(clock)"
        },
        {
          "id": "rene-yt-music-view",
          "name": "YT Music",
          "icon": "$(music)"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "esbuild": "^0.27.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}